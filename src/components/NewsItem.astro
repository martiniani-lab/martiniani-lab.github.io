---
interface Props {
  date: string;
  text: string;
  link?: string;
}

const { date, text, link } = Astro.props;

// js-yaml parses bare ISO dates as Date objects; handle both
const d = date instanceof Date ? date : new Date(date + 'T00:00:00');
const formatted = d.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Convert markdown-style [text](url) to HTML links
const rendered = text.replace(
  /\[([^\]]+)\]\(([^)]+)\)/g,
  '<a href="$2" target="_blank" rel="noopener">$1</a>'
);
---

<article class="news-item">
  <span class="news-date">{formatted}</span>
  {link ? (
    <p><a href={link} target="_blank" rel="noopener" set:html={rendered} /></p>
  ) : (
    <p set:html={rendered} />
  )}
</article>
