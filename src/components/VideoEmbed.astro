---
interface Props {
  title: string;
  youtubeId: string;
  description?: string;
}

const { title, youtubeId, description } = Astro.props;
const thumbUrl = `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`;
---

<div class="video-facade" data-youtube-id={youtubeId} aria-label={`Play video: ${title}`}>
  <img src={thumbUrl} alt={title} loading="lazy" decoding="async" />
  <div class="play-btn"></div>
</div>
{title && <p style="margin-top: 0.5em;"><strong>{title}</strong></p>}
{description && <p style="font-size: 0.9em;">{description}</p>}

<script is:inline>
  document.querySelectorAll('.video-facade').forEach(facade => {
    facade.addEventListener('click', function() {
      const id = this.dataset.youtubeId;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
      iframe.allow = 'autoplay; encrypted-media';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;';
      this.innerHTML = '';
      this.appendChild(iframe);
    }, { once: true });
  });
</script>
