---
import PageLayout from '../layouts/PageLayout.astro';
import TeamMember from '../components/TeamMember.astro';
import { loadTeam, getTeamByRole } from '../lib/data';
import { join } from 'node:path';

const team = loadTeam(join(process.cwd(), 'src/content/team.yaml'));
const groups = getTeamByRole(team);

const roleLabels: Record<string, string> = {
  pi: 'Principal Investigator',
  postdoc: 'Postdocs and Research Scientists',
  graduate: 'Graduate Students',
  staff: 'Research Staff',
  undergraduate: 'Undergraduates',
};

// Find PI for the spotlight section
const pi = groups['pi']?.[0];
const otherGroups = Object.entries(groups).filter(([role]) => role !== 'pi');

// Resolve team images via import.meta.glob
const teamImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/team/*.{jpg,jpeg,png,webp}');

async function resolveTeamImage(filename: string): Promise<string> {
  const fullPath = `/src/assets/images/team/${filename}`;
  if (teamImages[fullPath]) {
    const mod = await teamImages[fullPath]();
    return mod.default.src;
  }
  return '';
}

const groupImgSrc = await resolveTeamImage('group.jpg');
const piImgSrc = pi?.image ? await resolveTeamImage(pi.image) : '';
---

<PageLayout
  title="Team — Martiniani Lab"
  description="Meet the ~26 researchers at Martiniani Lab, NYU — led by Stefano Martiniani, working across AI for materials, world models, neural circuit theory, and statistical physics."
  heading="The Team"
>
  <!-- Group photo -->
  {groupImgSrc && (
    <span class="image fit" style="margin-bottom: 2em;">
      <img src={groupImgSrc} alt="Martiniani Lab group photo" loading="eager" />
    </span>
  )}

  <!-- PI Spotlight -->
  {pi && (
    <section class="spotlights">
      <section>
        <div class="image">
          <img src={piImgSrc} alt={pi.name} />
        </div>
        <div class="content">
          <div class="inner">
            <header class="minor">
              <h3>Principal Investigator</h3>
            </header>
            <p>{pi.bio}</p>
            <p>For details, see <a href="/pdf/cv.pdf" target="_blank">CV</a>.</p>
          </div>
        </div>
      </section>
    </section>
  )}

  <!-- Team groups -->
  {otherGroups.map(([role, members]) => (
    <section>
      <h3>{roleLabels[role] || role}</h3>
      <div class="row gtr-200 gtr-uniform">
        {members.map(m => (
          <TeamMember name={m.name} image={m.image} title={m.title} />
        ))}
      </div>
    </section>
  ))}

  <ul class="actions">
    <li><a href="/alumni" class="button next">Alumni</a></li>
  </ul>
</PageLayout>
