---
import PageLayout from '../layouts/PageLayout.astro';
import { loadTeaching } from '../lib/data';
import { join } from 'node:path';

const teaching = loadTeaching(join(process.cwd(), 'src/content/teaching.yaml'));
---

<PageLayout
  title="Teaching — Martiniani Lab"
  description="Courses by Stefano Martiniani at NYU and UMN — Physics of Neural Systems, Machine Learning for Chemical Sciences, Thermodynamics, Mathematical Physics."
  heading="Teaching"
>
  {teaching.map(inst => (
    <section style="margin-bottom: 3em;">
      <h2>{inst.institution}</h2>
      <p style="font-size: 0.85em; color: rgba(255,255,255,0.5);">{inst.years}</p>
      <ul style="list-style: disc; padding-left: 1.5em;">
        {inst.courses.map(course => (
          <li style="margin-bottom: 0.5em;">
            <strong>{course.name}</strong>
            {course.code && <span style="font-size: 0.85em;"> ({course.code})</span>}
            {course.description && <p style="font-size: 0.9em; margin-top: 0.25em;">{course.description}</p>}
          </li>
        ))}
      </ul>
    </section>
  ))}
</PageLayout>
