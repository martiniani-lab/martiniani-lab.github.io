---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Curriculum Vitae — Stefano Martiniani"
  description="Curriculum Vitae of Stefano Martiniani, Assistant Professor at New York University. Research in statistical mechanics, machine learning, soft matter, neuroscience, and materials science."
  heading="Curriculum Vitae"
>
  <style is:global>
    .cv-download {
        margin-bottom: 2em;
        text-align: right;
      }
      .cv-section {
        margin-bottom: 2.5em;
      }
      .cv-section h2 {
        color: #9bf1ff;
        font-size: 1.3em;
        font-weight: 600;
        letter-spacing: 0.05em;
        border-bottom: 2px solid rgba(155, 241, 255, 0.3);
        padding-bottom: 0.3em;
        margin-bottom: 1em;
      }
      .cv-entry {
        margin-bottom: 1.2em;
      }
      .cv-entry-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.5em;
      }
      .cv-entry-header .title {
        font-weight: 600;
        color: #ffffff;
      }
      .cv-entry-header .date {
        color: rgba(255, 255, 255, 0.6);
        white-space: nowrap;
        font-size: 0.95em;
      }
      .cv-entry .institution {
        color: rgba(255, 255, 255, 0.8);
      }
      .cv-entry .details {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.95em;
        padding-left: 1.5em;
      }
      .cv-summary-grid {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.4em 1.5em;
        font-size: 0.95em;
      }
      .cv-summary-grid dt {
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
        white-space: nowrap;
      }
      .cv-summary-grid dd {
        margin: 0;
        color: rgba(255, 255, 255, 0.7);
      }
      .cv-pub-list {
        list-style: none;
        padding: 0;
        counter-reset: none;
      }
      .cv-pub-list li {
        margin-bottom: 0.8em;
        padding-left: 2.5em;
        text-indent: -2.5em;
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.95em;
        line-height: 1.6;
      }
      .cv-pub-list .pub-number {
        display: inline-block;
        width: 2em;
        text-align: right;
        margin-right: 0.5em;
        color: rgba(255, 255, 255, 0.5);
        font-weight: 600;
      }
      .cv-pub-list .pub-highlight {
        display: block;
        padding-left: 2.5em;
        text-indent: 0;
        color: rgba(155, 241, 255, 0.7);
        font-size: 0.9em;
        margin-top: 0.2em;
      }
      .cv-funding-list {
        list-style: none;
        padding: 0;
      }
      .cv-funding-list li {
        margin-bottom: 0.8em;
        padding-left: 2.5em;
        text-indent: -2.5em;
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.95em;
        line-height: 1.6;
      }
      .cv-teaching-group {
        margin-bottom: 1.5em;
      }
      .cv-teaching-group h3 {
        font-size: 1em;
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 0.5em;
      }
      .cv-teaching-group ul {
        list-style: none;
        padding-left: 1.5em;
      }
      .cv-teaching-group li {
        margin-bottom: 0.3em;
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.95em;
      }
      .cv-service-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95em;
      }
      .cv-service-table td {
        padding: 0.3em 0.5em;
        color: rgba(255, 255, 255, 0.7);
        vertical-align: top;
        border: none;
      }
      .cv-service-table td:first-child {
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
        white-space: nowrap;
        width: 12em;
      }
      .cv-service-table td:last-child {
        text-align: right;
        white-space: nowrap;
        width: 8em;
      }
      .cv-talks-list {
        list-style: none;
        padding: 0;
      }
      .cv-talks-list li {
        margin-bottom: 0.6em;
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.95em;
        line-height: 1.5;
      }
      .cv-talks-list .talk-title {
        font-style: italic;
        color: rgba(255, 255, 255, 0.6);
      }
      .cv-trainee-section {
        margin-bottom: 1.5em;
      }
      .cv-trainee-section h3 {
        font-size: 1.05em;
        color: rgba(155, 241, 255, 0.8);
        margin-bottom: 0.5em;
      }
      .cv-trainee {
        margin-bottom: 1em;
        font-size: 0.95em;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.5;
      }
      .cv-trainee strong {
        color: rgba(255, 255, 255, 0.9);
      }
      .cv-note {
        font-size: 0.85em;
        color: rgba(255, 255, 255, 0.5);
        margin-top: 0.5em;
      }
      .cv-pub-annotation {
        font-size: 0.9em;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 1em;
        font-style: italic;
      }
      @media (max-width: 736px) {
        .cv-entry-header {
          flex-direction: column;
          gap: 0.2em;
        }
        .cv-summary-grid {
          grid-template-columns: 1fr;
          gap: 0.2em 0;
        }
        .cv-summary-grid dt {
          margin-top: 0.5em;
        }
        .cv-service-table td:first-child {
          white-space: normal;
        }
      }
    </style>

  <div class="cv-download">
    <a href="/pdf/cv.pdf" target="_blank" class="button primary">Download PDF</a>
  </div>

