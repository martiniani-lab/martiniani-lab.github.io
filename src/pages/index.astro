---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResearchTile from '../components/ResearchTile.astro';
import NewsItem from '../components/NewsItem.astro';
import JsonLd from '../components/JsonLd.astro';
import { loadHighlights, loadNews, getLatestNews } from '../lib/data';
import { join } from 'node:path';

const contentDir = join(process.cwd(), 'src/content');
const highlights = loadHighlights(join(contentDir, 'highlights.yaml'));
const allNews = loadNews(join(contentDir, 'news.yaml'));
const latestNews = getLatestNews(allNews, 7);
---

<BaseLayout
  title="Martiniani Lab — NYU"
  description="Martiniani Lab at NYU — developing AI to accelerate discovery in molecular, material, and living systems, and establishing a theory of intelligence grounded in physical principles."
  transparentHeader={true}
>
  <JsonLd slot="head" />

  <!-- Banner -->
  <section id="banner" class="major" style="background-image: url('/images/banner.jpg');">
    <div class="inner">
      <header class="major">
        <h1>Martiniani Lab at NYU</h1>
      </header>
      <h3 class="content">
        <p>Harnessing Disorder in Natural and Artificial Systems</p>
      </h3>
      <ul class="actions">
        <li><a href="#one" class="button next scrolly">Let's wander</a></li>
      </ul>
    </div>
  </section>

  <div id="main">
    <!-- Research Highlights -->
    <section id="one" class="tiles">
      {highlights.map(h => (
        <ResearchTile
          title={h.title}
          subtitle={h.subtitle}
          image={h.image}
          link={h.link}
          color={h.color}
        />
      ))}
    </section>

    <!-- About -->
    <section id="about">
      <div class="inner">
        <header class="major">
          <h2>About us</h2>
        </header>
        <p>We are a team of problem solvers dedicated to discovering the fundamental principles governing the behaviour of both natural and artificial systems through the development of new mathematical and computational approaches to characterize/engineer order, function, and learning in complex systems.</p>

        <p>Our team is composed of theoretical physicists, applied mathematicians, and theoretical chemists doing true interdisciplinary theoretical research. We seek to answer questions like: What is the mechanism by which cortical areas in the brain communicate? Can we engineer disorder in material systems to tune their function? What is the basic mechanisms by which stochastic optimization leads to optimal solutions in machine learning and statistical physics models? How can we extend thermodynamic concepts to systems far from equilibrium? How can we learn a representation of chemical space that rivals the representational capacity of machine learning models for language and vision?</p>

        <p>We have introduced computational and theoretical frameworks that revealed striking regularities in physical systems for which one would expect none, and that enabled us to answer questions that could have never been approached with existing techniques. While we relish mathematical and computational sophistication, we are visual thinkers seeking ever simpler representations of complex concepts, and more intutive approaches to solving difficult problems.</p>

        <ul class="actions fit small">
          <li><a href="/team" class="button fit">The Team</a></li>
          <li><a href="/publications" class="button fit">Publications</a></li>
        </ul>

        <ul class="actions fit small">
          <li><a href="/software" class="button fit">Software</a></li>
          <li><a href="/teaching" class="button fit">Teaching</a></li>
        </ul>

        <ul class="actions fit small">
          <li><a href="/press" class="button fit">Covers, Press & Podcasts</a></li>
          <li><a href="/funding" class="button fit">Funding</a></li>
        </ul>

        <ul class="actions fit small">
          <li><a href="/gallery" class="button fit">Video Gallery</a></li>
        </ul>
      </div>
    </section>

    <!-- Latest News -->
    <section id="three">
      <div class="inner">
        <header class="major">
          <h2>Latest news</h2>
        </header>
        {latestNews.map(item => (
          <NewsItem date={item.date} text={item.text} link={item.link} />
        ))}
        <ul class="actions">
          <li><a href="/news" class="button">More news</a></li>
        </ul>
      </div>
    </section>

  </div>
</BaseLayout>
